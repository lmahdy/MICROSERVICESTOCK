{
  "realm": "orderly",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "CLIENT",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "LIVREUR",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "default-roles-orderly",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["offline_access", "uma_authorization", "CLIENT"]
        },
        "clientRole": false
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-orderly",
    "composite": true,
    "composites": {
      "realm": ["offline_access", "uma_authorization", "CLIENT"]
    }
  },
  "clients": [
