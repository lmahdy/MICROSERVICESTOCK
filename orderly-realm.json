      "rootUrl": "http://localhost:4200",
      "redirectUris": ["http://localhost:4200/*", "http://localhost:80/*", "http://localhost/*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "frontchannelLogout": true,
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4200/*"
      }
    }
  ],
